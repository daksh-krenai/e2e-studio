    "build": "cd ui && npm run build",
    "setup": "npm install && cd ui && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.11",
    "ws": "^8.16.0",
    "uuid": "^9.0.1",
    "concurrently": "^8.2.2",
    "lowdb": "^7.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
